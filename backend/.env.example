# Optional overrides — sensible defaults are used if unset.
LOG_LEVEL=INFO
UPLOAD_DIR=uploads
MAX_FILE_SIZE_BYTES=52428800

# Similarity gate for /query. Lowered from an initial 0.35 after live testing
# showed natural-language questions score materially lower than keyword-style
# queries against all-MiniLM-L6-v2 (see ENGINEERING_DECISIONS.md).
RETRIEVAL_SIMILARITY_THRESHOLD=0.25

# Required for Groq answer generation and insights.
GROQ_API_KEY=
GROQ_MODEL=qwen/qwen3-32b
GROQ_TIMEOUT_SECONDS=30
